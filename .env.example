# =============================================================================
# Flowcheq Estate — Mobile app (.env.example)
# =============================================================================
# Expo only exposes variables prefixed with EXPO_PUBLIC_
#
# Local development — copy to `.env`:
#   cp .env.example .env
#
# Production builds — set in eas.json (already configured for production-apk)
# or EAS secrets:
#   eas secret:create --name EXPO_PUBLIC_API_URL --value https://api.estate.flowcheq.com
#
# Never commit `.env` with real tokens.
# =============================================================================

# --- Required (production) ---

# Backend API — use your LAN IP for physical device dev, production URL for EAS builds
# Dev on phone:  EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
# Production:    EXPO_PUBLIC_API_URL=https://api.estate.flowcheq.com
EXPO_PUBLIC_API_URL=https://api.estate.flowcheq.com

# Optional public web URL for opening full dashboard/help pages from app links
EXPO_PUBLIC_WEB_URL=https://estate.flowcheq.com

# App deep link scheme (must match app.json "scheme" and backend MOBILE_APP_URL)
# flowcheq://verify-account?fee=success

# --- Development only ---

# Pre-fill JWT for testing without web login flow (never use in production builds)
# EXPO_PUBLIC_AUTH_TOKEN=
