{
  "expo": {
    "name": "Flowcheq Agent",
    "slug": "flowcheq-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "flowcheq",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F8F9FA",
    "primaryColor": "#007AFF",
    "splash": {
      "backgroundColor": "#007AFF",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flowcheq.estate",
      "infoPlist": {
        "NSCameraUsageDescription": "Flowcheq Capture needs the camera for GPS-verified listing photos.",
        "NSLocationWhenInUseUsageDescription": "Flowcheq Capture stamps each photo with your live location."
      }
    },
    "android": {
      "package": "com.flowcheq.estate",
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "flowcheq",
              "host": "verify-account"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#007AFF"
      }
    },
    "plugins": ["expo-router", ["expo-camera"], ["expo-location"]]
  }
}
